{
  "manifest_version": 3,
  "name": "DeshittyfIn",
  "version": "1.0",
  "permissions": ["storage", "activeTab"],
  "action": {
    "default_popup": "src/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["src/content.js"]
    }
  ],
  "icons": {
    "16": "media/icons/icon16.png",
    "32": "media/icons/icon32.png",
    "48": "media/icons/icon48.png",
    "128": "media/icons/icon128.png"
  }
}